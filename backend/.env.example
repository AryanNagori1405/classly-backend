# .env.example
# Copy this file to .env and fill in your actual values.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_HOST=localhost
DB_NAME=classly_db
DB_PASSWORD=your_db_password_here
DB_PORT=5432

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long, random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.  Leave empty to allow all.
# Example for web: ALLOWED_ORIGINS=http://localhost:3000,https://yourapp.com
ALLOWED_ORIGINS=

# ── Optional: SMTP (for OTP delivery via email) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_app_password
SMTP_FROM=no-reply@classly.app
