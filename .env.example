# .env.example

# Database credentials
DATABASE_URL="postgres://user:password@localhost:5432/mydatabase"  # URL Format: 'postgres://<user>:<password>@<host>:<port>/<database>'

# JWT secret
JWT_SECRET="your_jwt_secret_here"  # Secret key for signing JSON Web Tokens

# Server port configuration
PORT=3000  # Port where the application will run

# File upload settings
FILE_UPLOAD_PATH="uploads/"  # Path for file uploads
MAX_FILE_SIZE=5242880  # Maximum file size in bytes (5MB)

# Other configurations
APP_NAME="Classly Backend"  # Name of the application
NODE_ENV="development"  # Environment mode (development/production)
